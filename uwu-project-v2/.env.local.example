# ============================================================================
# uwu-project-v2 - beda arsitektur dari v1: TIDAK ADA lagi tab "Level Fasil"
# gabungan. Sumber data satu-satunya adalah 30 spreadsheet LK Fasil PRIBADI
# (satu per fasilitator), ditemukan lewat SATU spreadsheet "controller".
# Lihat README.md untuk detail arsitektur (sudah terkonfirmasi dari contoh
# nyata, bukan tebakan lagi).
#
# STATUS PER 2026-07-16: CONTROLLER_SHEET_URL sudah berfungsi (controller +
# tab "Isian" tiap LK fasilitator sudah bisa dibaca, terverifikasi live
# Push balik analisis (lib/writeSheet.ts) sekarang langsung memakai akses API 
# dari Google OAuth login Admin (tidak butuh setup Apps Script Webhook lagi).
# ============================================================================

# --- Login Google (menggantikan alur berbasis webhook) - SELURUH app di
# balik middleware.ts, wajib login dulu sebelum bisa akses apa pun selain
# /login. Setelah login, admin WAJIB pilih satu nama Atmin di /pilih-admin
# (dipakai nanti untuk memfilter log per admin) sebelum lanjut ke dashboard.
#
# 1) Buat OAuth Client ID (tipe "Web application") di Google Cloud Console >
#    APIs & Services > Credentials. Authorized redirect URI WAJIB persis:
#    http://localhost:3000/api/auth/callback/google (ganti host/port sesuai
#    domain produksi kalau di-deploy).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 2) Secret buat enkripsi session JWT NextAuth - generate sekali lewat
#    `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`.
#    (Jangan pakai `npx auth secret` karena itu untuk library better-auth, bukan NextAuth).
AUTH_SECRET=

# 3) Whitelist email Google TAMBAHAN yang BOLEH login, pisah koma. Email yang
#    sudah ada di ADMIN_EMAIL_MAP (di lib/admins.ts) otomatis diizinkan. KOSONG =
#    hanya izinkan email dari map tersebut. Jika email tidak ada di map dan env
#    var ini kosong = login ditolak (fail-closed).
ADMIN_EMAILS=

# URL Google Sheet "controller" - tab "Fasilitator" (Atmin, Kode Fasil, Nama
# Fasil, Tautan ke LK pribadi tiap fasilitator) + tab "Check Point" (jadwal
# checkpoint, dibaca otomatis lewat nama tab - lihat lib/sheet.ts). Sheet
# controller HARUS di-share "Anyone with the link" bisa view - dan PENTING:
# tiap dari 30 spreadsheet LK individual di baliknya JUGA harus di-share
# terpisah (sharing controller tidak menular ke sheet yang di-link-nya).
# Kosongkan untuk tetap memakai data contoh.
CONTROLLER_SHEET_URL=

# --- Provider AI untuk analisis - SAMA PERSIS dengan v1 (lib/llm.ts di
# packages/core dipakai bareng oleh v1 & v2, tidak diubah sama sekali), lihat
# README v1 untuk penjelasan lengkap tiap provider & urutan fallback-nya.
# Isi minimal SATU dari lima blok di bawah.

# 1) Hugging Face (buat token di https://huggingface.co/settings/tokens).
HF_TOKEN=
HF_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# 2) Google Gemini / Google AI Studio (buat API key gratis di
# https://aistudio.google.com/apikey).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 3) Groq (buat API key gratis di https://console.groq.com/keys).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 4) OpenRouter (buat API key gratis di https://openrouter.ai/keys).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 5) OpenAI (BERBAYAR - buat API key di https://platform.openai.com/api-keys).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# (Opsional) Jangkar manual siklus 14 hari - dipakai HANYA sebagai fallback
# kalau tab "Check Point" gagal diambil (lihat lib/sheet.ts::getTodayHari).
# CYCLE_ANCHOR_DATE format YYYY-MM-DD = tanggal kalender untuk "Hari ke-" =
# CYCLE_ANCHOR_HARI. Default: 2026-07-06 = Hari 1.
CYCLE_ANCHOR_HARI=1
CYCLE_ANCHOR_DATE=2026-07-06

# (Opsional) Override gid tab "Matriks" (skor akhir tiap fasilitator) kalau
# beda dari default di bawah - dikonfirmasi di SATU dari 30 spreadsheet LK
# (2026-07-16), belum diverifikasi semuanya sama. Lihat README.md.
MATRIKS_GID=447897018

# --- Notifikasi otomatis (halaman /laporan) - infra sama persis dengan v1,
# lib/notify.ts & lib/notifyState.ts tidak diubah.
NOTIFY_WEBHOOK_URL=
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=

