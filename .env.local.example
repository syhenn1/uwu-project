# URL Google Sheet publik yang berisi data monitoring fasilitator, tab "Level Fasil".
# Cara mendapatkan:
#   1. Buka file Google Sheets-nya, pastikan share access "Anyone with the link" bisa view.
#   2. Klik tab "Level Fasil" di bagian bawah supaya tab itu yang aktif.
#   3. Copy URL dari address bar apa adanya (boleh URL "edit" biasa, dengan atau tanpa
#      #gid=... di ujungnya) - otomatis dikonversi ke endpoint export CSV oleh aplikasi.
# Jika kosong, dashboard otomatis memakai data contoh di fixtures/sample-sheet.csv.
SHEET_CSV_URL=

# --- Provider AI untuk analisis (halaman detail fasilitator, Analisis Massal) ---
# Isi minimal SATU dari empat blok di bawah. Kalau isi lebih dari satu, aplikasi
# otomatis fallback berurutan: Hugging Face -> Google Gemini -> Groq -> OpenAI -
# kalau satu provider gagal (kuota habis, rate limit, dsb), lanjut coba yang
# berikutnya tanpa perlu ubah kode. Lihat lib/llm.ts.

# 1) Hugging Face (buat token di https://huggingface.co/settings/tokens).
# Model Llama 4 di bawah ini "gated" - buka halaman modelnya di huggingface.co
# dan klik terima lisensi Meta dulu sebelum token bisa dipakai memanggilnya.
HF_TOKEN=
HF_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct

# 2) Google Gemini / Google AI Studio (buat API key gratis di
# https://aistudio.google.com/apikey - tidak perlu kartu kredit untuk tier gratis).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# 3) Groq (buat API key gratis di https://console.groq.com/keys - inferensi
# Llama super cepat, ada tingkatan gratis).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 4) OpenAI (buat API key di https://platform.openai.com/api-keys - BERBAYAR,
# tidak ada tingkatan gratis, perlu kartu kredit/saldo di akun OpenAI-nya).
# Ditaruh paling akhir di urutan fallback karena berbayar - dipakai sebagai
# cadangan terakhir kalau tiga provider gratis di atas semuanya gagal.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# (Opsional) gid tab "Check Point", kalau beda dari default yang sudah di-hardcode.
SHEET_CHECKPOINT_GID=

# --- Notifikasi otomatis (halaman /laporan, tombol "Cek Sekarang") ---
# Isi SALAH SATU (atau keduanya) di bawah ini. Kosongkan semua untuk menonaktifkan.

# Webhook generik - kompatibel langsung dengan Slack/Discord/Mattermost
# "Incoming Webhook" (kirim {"text": "..."}), atau arahkan ke Zapier/Make untuk
# diteruskan ke email/WhatsApp/dsb.
NOTIFY_WEBHOOK_URL=

# Email langsung lewat Resend (resend.com, ada tier gratis). Ketiganya wajib
# diisi bersamaan kalau mau pakai jalur ini.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=

# --- Tulis balik ke spreadsheet (halaman /analisis-massal, tombol "Tambahkan ke Spreadsheet") ---
# Aplikasi ini sendiri tidak punya kredensial Google - satu-satunya jalur tulis
# adalah lewat Apps Script Web App yang kamu deploy sendiri dari spreadsheet-nya.
# Lihat google-apps-script/save-analisis.gs untuk kode & langkah deploy lengkap.
# Kosongkan untuk menonaktifkan tombol (akan tampil pesan error yang jelas).
WRITE_SHEETS_WEBHOOK_URL=
WRITE_SHEETS_WEBHOOK_SECRET=

# --- Panel "LK Fasilitator" di halaman detail fasilitator (opsional) ---
# Pemetaan Kode Fasil -> spreadsheet LK Fasil pribadi tiap fasilitator, sebagai
# JSON satu baris. Kosongkan untuk menonaktifkan panel (akan tampil pesan
# "belum dipetakan" per fasilitator, bukan error). Cara generate: lihat
# komentar di lib/facilitatorLkLinks.ts (proses manual, bongkar file .xlsx
# workbook utama untuk ambil hyperlink kolom B tab "Fasilitator").
# Contoh bentuknya:
# FACILITATOR_LK_LINKS_JSON={"KODE-Fasil-1":{"spreadsheetId":"...","gid":"..."}}
FACILITATOR_LK_LINKS_JSON=
